DB_USER=postgres
DB_PASS=postgres
DB_HOST=test-postgres-postgresql.test-postgres.svc.cluster.local
DB_PORT=5432
DB_NAME=ragdb

# paths
MODEL_PATH=/app/rag_app/models/llama-2-7b-chat.Q4_K_M.gguf
EMBEDDING_MODEL=/app/rag_app/models/embedding/all-MiniLM-L6-v2

# ---- SFDC Integration ----
SFDC_ENABLED=true
SF_URL=https://hp.my.salesforce.com

# Auth Mode 1: Session ID (env var or path to file - works on Windows and Linux)
# In K8s: mounted from Secret at /etc/sfdc/sid.txt
# Locally: set SF_SID_FILE to your sid.txt path
SF_SID=
SF_SID_FILE=/etc/sfdc/sid.txt

# Auth Mode 2: OAuth2 password flow (alternative to SID)
SFDC_CLIENT_ID=
SFDC_CLIENT_SECRET=
SFDC_USERNAME=
SFDC_PASSWORD=
SFDC_SECURITY_TOKEN=
SFDC_LOGIN_URL=https://login.salesforce.com

SFDC_SEARCH_LIMIT=10